# ==============================
# Django / Python
# ==============================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Django stuff
*.log
*.pot
*.pyc
db.sqlite3
db.sqlite3-journal

# Media — user-uploaded files
# On AWS/production, use S3 (DEFAULT_FILE_STORAGE = 'storages.backends.s3boto3.S3Boto3Storage')
# Only ignore actual uploads, NOT the media directory structure
media/post_images/*
media/profile_pics/*
!media/.gitkeep

# Collected static files (generated by `python manage.py collectstatic`)
staticfiles/

# Migrations (optional — remove if you want to track them)
# */migrations/*
# !*/migrations/__init__.py

# Environment variables
.env
.env.*
!.env.example

# Packaging
dist/
build/
*.egg-info/
.eggs/

# Testing
.coverage
coverage/
htmlcov/
.pytest_cache/

# ==============================
# Svelte / Node
# ==============================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# SvelteKit build output
.svelte-kit/
build/
dist/

# Environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==============================
# IDE / OS
# ==============================

.vscode/
.idea/
.DS_Store
Thumbs.db
treestagram_project/treestagram-svelte/node_modules/
